@startuml NautiGo_Class_Diagram
!theme plain
skinparam classAttributeIconSize 0
skinparam linetype ortho

' Package: entity
package "com.nautigo.entity" {
  class Usuario <<entity>> {
    -Long id {PK}
    -String email {unique}
    -String senha
    -String nome
    -String telefone
    -Boolean isAdmin
    -Boolean ativo
    -LocalDateTime dataCriacao
    -LocalDateTime dataAtualizacao
    +getAuthorities() : Collection<GrantedAuthority>
    +getPassword() : String
    +getUsername() : String
    +isAccountNonExpired() : boolean
    +isAccountNonLocked() : boolean
    +isCredentialsNonExpired() : boolean
    +isEnabled() : boolean
    #onCreate() : void {@PrePersist}
    #onUpdate() : void {@PreUpdate}
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class Passageiro <<entity>> {
    -Long id {PK}
    -LocalDateTime dataCriacao
    -LocalDateTime dataAtualizacao
    #onCreate() : void {@PrePersist}
    #onUpdate() : void {@PreUpdate}
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class Marinheiro <<entity>> {
    -Long id {PK}
    -String numeroDocumentoMarinha
    -String tipoEmbarcacao
    -String nomeEmbarcacao
    -String numeroRegistroEmbarcacao
    -Integer capacidadePassageiros
    -StatusAprovacao statusAprovacao
    -String observacoes
    -LocalDateTime dataCriacao
    -LocalDateTime dataAtualizacao
    #onCreate() : void {@PrePersist}
    #onUpdate() : void {@PreUpdate}
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  enum StatusAprovacao {
    PENDENTE
    APROVADO
    REJEITADO
  }
  
  class Viagem <<entity>> {
    -Long id {PK}
    -String origem
    -String destino
    -String observacoes
    -LocalDateTime dataHoraSolicitada
    -LocalDateTime dataHoraAgendada
    -LocalDateTime dataHoraIniciada
    -LocalDateTime dataHoraConcluida
    -StatusViagem status
    -MetodoPagamento metodoPagamento
    -Integer numeroPessoas
    -BigDecimal valor
    -BigDecimal valorPropostoPassageiro
    -BigDecimal valorContraPropostaMarinheiro
    -LocalDateTime dataCriacao
    -LocalDateTime dataAtualizacao
    #onCreate() : void {@PrePersist}
    #onUpdate() : void {@PreUpdate}
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  enum StatusViagem {
    PENDENTE
    AGUARDANDO_APROVACAO_PASSAGEIRO
    ACEITA
    EM_ANDAMENTO
    CONCLUIDA
    CANCELADA
  }
  
  enum MetodoPagamento {
    DINHEIRO
    PIX
  }
  
  class Avaliacao <<entity>> {
    -Long id {PK}
    -Integer nota
    -String comentario
    -LocalDateTime dataCriacao
    #onCreate() : void {@PrePersist}
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class ViagemRecusada <<entity>> {
    -Long id {PK}
    -LocalDateTime dataRecusa
    #onCreate() : void {@PrePersist}
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  ' Relationships in entity package
  Passageiro "1" --> "1" Usuario : @OneToOne\nusuario
  Marinheiro "1" --> "1" Usuario : @OneToOne\nusuario
  Viagem "0..*" --> "1" Passageiro : @ManyToOne\npassageiro
  Viagem "0..*" --> "0..1" Marinheiro : @ManyToOne\nmarinheiro
  Avaliacao "0..*" --> "1" Viagem : @ManyToOne\nviagem
  Avaliacao "0..*" --> "1" Usuario : @ManyToOne\navaliador
  Avaliacao "0..*" --> "1" Usuario : @ManyToOne\navaliado
  ViagemRecusada "0..*" --> "1" Viagem : @ManyToOne\nviagem
  ViagemRecusada "0..*" --> "1" Marinheiro : @ManyToOne\nmarinheiro
  Marinheiro ..> StatusAprovacao : uses
  Viagem ..> StatusViagem : uses
  Viagem ..> MetodoPagamento : uses
}

' Package: dto
package "com.nautigo.dto" {
  class LoginRequest <<dto>> {
    -String email
    -String senha
    .. Lombok: @Data ..
  }
  
  class LoginResponse <<dto>> {
    -String token
    -UserResponse user
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class CadastroPassageiroRequest <<dto>> {
    -String nome
    -String email
    -String telefone
    -String senha
    .. Lombok: @Data ..
  }
  
  class CadastroMarinheiroRequest <<dto>> {
    -String nome
    -String email
    -String telefone
    -String senha
    -String numeroDocumentoMarinha
    -String tipoEmbarcacao
    -String nomeEmbarcacao
    -String numeroRegistroEmbarcacao
    -Integer capacidadePassageiros
    .. Lombok: @Data ..
  }
  
  class SolicitarViagemRequest <<dto>> {
    -String origem
    -String destino
    -String observacoes
    -LocalDateTime dataHoraAgendada
    -MetodoPagamento metodoPagamento
    -Integer numeroPessoas
    -BigDecimal valorPropostoPassageiro
    .. Lombok: @Data ..
  }
  
  class ViagemResponse <<dto>> {
    -Long id
    -Long passageiroId
    -String passageiroNome
    -Long marinheiroId
    -String marinheiroNome
    -String origem
    -String destino
    -String observacoes
    -LocalDateTime dataHoraSolicitada
    -LocalDateTime dataHoraAgendada
    -LocalDateTime dataHoraIniciada
    -LocalDateTime dataHoraConcluida
    -StatusViagem status
    -MetodoPagamento metodoPagamento
    -Integer numeroPessoas
    -String nomeBarco
    -Double notaMediaMarinheiro
    -Double notaMediaPassageiro
    -BigDecimal valor
    -BigDecimal valorPropostoPassageiro
    -BigDecimal valorContraPropostaMarinheiro
    -LocalDateTime dataCriacao
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class AvaliarViagemRequest <<dto>> {
    -Integer nota
    -String comentario
    .. Lombok: @Data ..
  }
  
  class AvaliacaoResponse <<dto>> {
    -Long id
    -Long viagemId
    -String avaliadorNome
    -String avaliadoNome
    -Integer nota
    -String comentario
    -LocalDateTime dataCriacao
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class MarinheiroResponse <<dto>> {
    -Long id
    -Long usuarioId
    -String nome
    -String email
    -String telefone
    -String numeroDocumentoMarinha
    -String tipoEmbarcacao
    -String nomeEmbarcacao
    -String numeroRegistroEmbarcacao
    -Integer capacidadePassageiros
    -String statusAprovacao
    -String observacoes
    -LocalDateTime dataCriacao
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class UserResponse <<dto>> {
    -Long id
    -String email
    -String nome
    -Boolean isAdmin
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  class PaginatedResponse <<dto>> {
    -List<T> content
    -int page
    -int size
    -long totalElements
    -int totalPages
    -boolean first
    -boolean last
    .. Lombok: @Data, @NoArgsConstructor, @AllArgsConstructor ..
  }
  
  SolicitarViagemRequest ..> MetodoPagamento : uses
  ViagemResponse ..> StatusViagem : uses
  ViagemResponse ..> MetodoPagamento : uses
}

' Package: repository
package "com.nautigo.repository" {
  interface UsuarioRepository <<repository>> {
    +Optional<Usuario> findByEmail(String email)
    +boolean existsByEmail(String email)
  }
  
  interface PassageiroRepository <<repository>> {
    +Optional<Passageiro> findByUsuario(Usuario usuario)
    +boolean existsByUsuario(Usuario usuario)
  }
  
  interface MarinheiroRepository <<repository>> {
    +Optional<Marinheiro> findByUsuario(Usuario usuario)
    +boolean existsByUsuario(Usuario usuario)
    +List<Marinheiro> findByStatusAprovacao(StatusAprovacao status)
  }
  
  interface ViagemRepository <<repository>> {
    +List<Viagem> findByPassageiroOrderByDataCriacaoDesc(Passageiro passageiro)
    +List<Viagem> findByMarinheiroOrderByDataCriacaoDesc(Marinheiro marinheiro)
    +List<Viagem> findByStatusOrderByDataCriacaoDesc(StatusViagem status)
    +List<Viagem> findByStatusAndMarinheiroIsNullOrderByDataCriacaoDesc(StatusViagem status)
    +List<Viagem> findByStatusAndMarinheiroIsNullAndIdNotInOrderByDataCriacaoDesc(StatusViagem status, List<Long> ids)
    +List<Viagem> findByPassageiroAndStatusInAndDataHoraAgendadaIsNull(Passageiro passageiro, List<StatusViagem> statuses)
    +List<Viagem> findByPassageiroAndStatusNotOrderByDataCriacaoDesc(Passageiro passageiro, StatusViagem status)
    +List<Viagem> findByMarinheiroAndStatusNotOrderByDataCriacaoDesc(Marinheiro marinheiro, StatusViagem status)
    +Page<Viagem> findByPassageiroAndStatusNotOrderByDataCriacaoDesc(Passageiro passageiro, StatusViagem status, Pageable pageable)
    +Page<Viagem> findByMarinheiroAndStatusNotOrderByDataCriacaoDesc(Marinheiro marinheiro, StatusViagem status, Pageable pageable)
  }
  
  interface AvaliacaoRepository <<repository>> {
    +List<Avaliacao> findByAvaliado(Usuario avaliado)
    +Optional<Avaliacao> findByViagemAndAvaliador(Viagem viagem, Usuario avaliador)
    +Double calcularMediaAvaliacoes(Usuario usuario)
    +Long contarAvaliacoes(Usuario usuario)
  }
  
  interface ViagemRecusadaRepository <<repository>> {
    +List<Long> findViagemIdsByMarinheiroId(Long marinheiroId)
    +boolean existsByViagem_IdAndMarinheiro_Id(Long viagemId, Long marinheiroId)
  }
  
  UsuarioRepository ..|> JpaRepository : extends
  PassageiroRepository ..|> JpaRepository : extends
  MarinheiroRepository ..|> JpaRepository : extends
  ViagemRepository ..|> JpaRepository : extends
  AvaliacaoRepository ..|> JpaRepository : extends
  ViagemRecusadaRepository ..|> JpaRepository : extends
  
  UsuarioRepository ..> Usuario : queries
  PassageiroRepository ..> Passageiro : queries
  PassageiroRepository ..> Usuario : queries
  MarinheiroRepository ..> Marinheiro : queries
  MarinheiroRepository ..> Usuario : queries
  MarinheiroRepository ..> StatusAprovacao : queries
  ViagemRepository ..> Viagem : queries
  ViagemRepository ..> Passageiro : queries
  ViagemRepository ..> Marinheiro : queries
  ViagemRepository ..> StatusViagem : queries
  AvaliacaoRepository ..> Avaliacao : queries
  AvaliacaoRepository ..> Usuario : queries
  AvaliacaoRepository ..> Viagem : queries
  ViagemRecusadaRepository ..> ViagemRecusada : queries
}

